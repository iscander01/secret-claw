{
  "$schema": "https://docs.openclaw.ai/schema/openclaw.json",
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "https://__VM_HOSTNAME__"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "update": {
    "checkOnStart": false,
    "auto": { "enabled": false }
  },
  "models": {
    "providers": {
      "secretai-rytn": {
        "baseUrl": "https://secretai-rytn.scrtlabs.com:21434",
        "apiKey": "__SECRETAI_API_KEY__",
        "api": "ollama",
        "timeoutSeconds": 300,
        "contextWindow": 262144,
        "maxTokens": 8192,
        "models": [
          {
            "id": "tripolskypetr/qwen3.5-uncensored-aggressive:27b",
            "name": "qwen3.5-uncensored",
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 8192,
            "params": {
              "num_ctx": 262144,
              "keep_alive": "10m"
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "secretai-rytn/tripolskypetr/qwen3.5-uncensored-aggressive:27b"
      },
      "compaction": {
        "reserveTokens": 4096,
        "maxActiveTranscriptBytes": 1000
      },
      "skills": [],
      "bootstrapMaxChars": 2000,
      "bootstrapTotalMaxChars": 8000
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Secret Agent"
      },
      {
        "id": "routines",
        "name": "Secret Agent-routines",
        "workspace": "/home/node/.openclaw/agents/routines/workspace",
        "agentDir": "/home/node/.openclaw/agents/routines/agent",
        "model": "secretai-rytn/tripolskypetr/qwen3.5-uncensored-aggressive:27b"
      }
    ]
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "exec",
      "dir_list",
      "web_fetch",
      "message"
    ]
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "diagnostics-prometheus": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "__TELEGRAM_BOT_TOKEN__",
      "dmPolicy": "allowlist",
      "allowFrom": ["__TELEGRAM_CHAT_ID__"]
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:__TELEGRAM_CHAT_ID__"
    ]
  },
  "cron": {
    "enabled": true,
    "store": "/home/node/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1
  }
}
