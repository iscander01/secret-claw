# Placeholder values matching the JSON config schema accepted by
# scripts/render.py. Use this only for manual rendering / testing without
# the wizard. The render script ignores .env entirely -- it reads a JSON
# config -- but this file documents the same set of fields in
# environment-variable form for humans who prefer that shape.
#
# TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are optional. If both are empty,
# the rendered compose ships with Telegram disabled and the recurring
# routines disabled (the agent stays reachable via the web UI). To enable
# Telegram later, the user uses the OpenClaw web UI to add credentials and
# re-enable the routines -- no re-render needed.

VM_HOSTNAME=amber-otter.vm.scrtlabs.com
ANTHROPIC_API_KEY=sk-ant-EXAMPLE_REPLACE_ME
TELEGRAM_BOT_TOKEN=0000000000:EXAMPLE_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CHAT_ID=0
